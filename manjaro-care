#!/usr/bin/env python3
# -*- coding: utf-8 -*-
"""
manjaro-care — نقطة الدخول الرئيسية.

الاستخدام:
    python3 manjaro-care
أو بعد التثبيت:
    manjaro-care
"""

import sys
import os

# يسمح بتشغيل التطبيق مباشرة من مجلد المصدر دون تثبيت (python3 manjaro-care)
sys.path.insert(0, os.path.dirname(os.path.abspath(__file__)))

from PyQt5.QtWidgets import QApplication
from PyQt5.QtCore import Qt

from gui.main_window import MainWindow


def main() -> int:
    os.environ.setdefault("QT_QPA_PLATFORMTHEME", "kde")  # يحترم إعداد المستخدم إن وُجد مسبقاً، ويجب ضبطه قبل QApplication
    app = QApplication(sys.argv)
    app.setApplicationName("Manjaro Care")
    app.setLayoutDirection(Qt.RightToLeft)

    # ثيم داكن بسيط متناسق مع KDE Plasma الافتراضي
    app.setStyleSheet("""
        QMainWindow, QWidget { background-color: #232323; color: #e0e0e0; }
        QPushButton {
            background-color: #3a3a3a; color: #e0e0e0;
            border: 1px solid #4a4a4a; border-radius: 6px; padding: 6px 14px;
        }
        QPushButton:hover { background-color: #454545; }
        QPushButton:pressed { background-color: #2a2a2a; }
    """)

    window = MainWindow()
    window.show()
    return app.exec_()


if __name__ == "__main__":
    sys.exit(main())
